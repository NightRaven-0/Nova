# Copy to .env and edit. Every value has a sensible default; uncomment to override.
# The defaults run Nova FULLY OFFLINE (Whisper + Ollama + Piper), no API keys.

# --- Backends -------------------------------------------------------------
# STT_BACKEND=whisper        # whisper (GPU) | vosk (light)
# LLM_BACKEND=ollama         # ollama (offline) | openai (cloud)
# TTS_BACKEND=piper          # piper (offline) | elevenlabs (cloud) | none (text only)

# --- Local LLM (Ollama) ---------------------------------------------------
# LOCAL_LLM_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Whisper STT ----------------------------------------------------------
# WHISPER_MODEL=small.en     # tiny[.en]/base[.en]/small[.en]/medium[.en]/large-v3
# WHISPER_DEVICE=cuda        # cuda | cpu
# WHISPER_COMPUTE_TYPE=float16   # use int8 on cpu

# --- Microphone -----------------------------------------------------------
# MIC_INDEX=                 # leave blank for default mic; run test_mic.py to list

# --- Wake word (Layer 3) --------------------------------------------------
# USE_WAKE_WORD=0            # 1 = only engage after the wake phrase
# WAKE_WORD_MODEL=hey_jarvis # hey_jarvis | alexa | hey_mycroft | hey_rhasspy
# WAKE_WORD_THRESHOLD=0.5

# --- Barge-in (Layer 3) ---------------------------------------------------
# USE_BARGE_IN=1             # 1 = talk over Nova to interrupt it (Piper only)
# BARGE_RMS_THRESHOLD=0.06   # raise if Nova interrupts itself; lower with headphones

# --- Cloud keys (only if you switch a backend to a cloud option) ----------
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# --- Optional VAE text cleaner (off by default; needs requirements-vae.txt)
# USE_VAE_TEXT_CLEANER=0
